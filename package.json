{
  "name": "docflow-mcp",
  "version": "0.2.0",
  "description": "MCP server that converts API docs into compact, task-aware context for reliable AI-assisted coding.",
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts",
    "dev:extract": "tsx src/dev/runExtract.ts",
    "eval:ab": "tsx src/eval/runAbEval.ts",
    "eval:workflow": "tsx src/eval/runWorkflowEval.ts",
    "eval:triage": "tsx src/eval/runEvalTriage.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "start:http": "node dist/src/http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "format": "prettier --write ."
  },
  "keywords": [
    "mcp",
    "documentation",
    "typescript",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "@mozilla/readability": "^0.6.0",
    "cheerio": "^1.1.0",
    "express": "^5.2.1",
    "jsdom": "^26.1.0",
    "turndown": "^7.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.15.29",
    "@types/turndown": "^5.0.5",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.27.0",
    "playwright": "^1.60.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
